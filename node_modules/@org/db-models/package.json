{
  "name": "@org/db-models",
  "version": "1.0.0",
  "description": "Shared Prisma schema and entities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "prisma/schema.prisma",
    "prisma/migrations"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "@prisma/client": "7.7.0"
  },
  "devDependencies": {
    "@prisma/client": "7.7.0",
    "prisma": "7.7.0",
    "typescript": "5.9.3"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./schema": "./prisma/schema.prisma"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  }
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../../../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// roles
enum Role {
  ADMIN
  USER
}

//User schema
model User {
  id        String   @id @default(uuid())
  name      String   @unique
  password  String
  role      Role     @default(USER)
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  servers   Server[] 
  archives  Archive[]
  campaigns Campaign[]   
  telegramChatId String? @unique
  telegramUserName String?
  token     String?
  tokenVersion Int   @default(0)
  tokenExpiry DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Campaign schema
model Campaign {
  id        String   @id @default(uuid())

  name      String
  alias     String
  geo       String[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Team schema
model Team {
  id      String @id @default(uuid())
  name    String @unique
  members User[]
  alias   String @default("")
}

//Archive schema
model Archive {
  id      String @id @default(uuid())
  name    String
  path    String
  userId  String
  user    User         @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())
}



///// Server and Domain schemas

model Server {
  id            String   @id
  name          String
  ip            String
  rootPassword  String
  forgePassword String
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])

  domains       Domain[]

  price         Float    @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  expiredAt     DateTime @default(dbgenerated("(now() + interval '1 month' - interval '1 day')"))
  assignedAt    DateTime?
  renewalAt     DateTime?

}

enum DomainType {
  INTERNAL
  EXTERNAL
}

enum DomainStatus {
  BAN
  FREEZE
  DO_NOT_WORK
  REPLACEMENT
  ACTIVE
  FAILED
  QUEUE
  INACTIVE
}

enum DeploymentType {
  FORGE
  SSH
}

model InternalDomain {
  domainId     String   @id
  domain       Domain   @relation(fields: [domainId], references: [id])
}

model ExternalDomain {
  domainId String   @id
  domain   Domain   @relation(fields: [domainId], references: [id])
}

model Domain {
  id        String      @id
  name      String      @unique
  type      DomainType

  status    DomainStatus @default(INACTIVE)

  serverId  String?
  server    Server?     @relation(fields: [serverId], references: [id], onDelete: SetNull)

  price     Float       @default(0)
  repoId    String
  sshUrl    String
  hasSSL    Boolean     @default(false)
  campaign  String      @default("")

  internal  InternalDomain?
  external  ExternalDomain?

  deploymentType DeploymentType @default(SSH)
}

model ForbiddenWord {
  id        String   @id @default(uuid())
  word      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

   @@index([isActive, word])
}

model NamecheapAccount {
  id          String   @id @default(uuid())

  username    String   @unique
  apiUser     String   
  apiKey      String

  contacts    Json?
}

model CloudflareAccount {
  id          String   @id @default(uuid())

  name        String   @unique
  apiToken    String
  accountId   String
}